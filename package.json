{
  "name": "fluidcad",
  "version": "0.0.1",
  "description": "FluidCAD core library",
  "author": "Marwan Aouida",
  "type": "module",
  "workspaces": [
    "extension/vscode",
    "packages/create-fluidcad-app"
  ],
  "bin": {
    "fluidcad": "./bin/fluidcad.js"
  },
  "files": [
    "lib/dist/",
    "server/dist/",
    "ui/dist/",
    "bin/"
  ],
  "exports": {
    ".": "./lib/dist/index.js",
    "./core": "./lib/dist/core/index.js",
    "./filters": "./lib/dist/filters/index.js",
    "./constraints": "./lib/dist/features/2d/constraints/geometry-qualifier.js",
    "./server": "./server/dist/index.js"
  },
  "scripts": {
    "build:lib": "tsc -p lib/tsconfig.json",
    "build:server": "tsc -p server/tsconfig.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "build": "npm run build:lib && npm run build:server && npm run build:ui",
    "prepublishOnly": "npm run build",
    "dev:lib": "tsc -p lib/tsconfig.json --watch",
    "dev:server": "node --experimental-transform-types --no-warnings server/src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:features": "vitest run lib/tests/features/"
  },
  "dependencies": {
    "color-name": "^2.1.0",
    "express": "^5.2.1",
    "occjs-fluidcad": "^1.0.0",
    "occjs-wrapper": "npm:occjs-fluidcad@^1.0.0",
    "vite": "^7.1.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tabler/icons": "^3.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.14.1",
    "@types/rbush": "^4.0.0",
    "@types/three": "^0.180.0",
    "@types/ws": "^8.18.0",
    "camera-controls": "^3.1.2",
    "daisyui": "^5.5.19",
    "eslint": "^9.24.0",
    "lodash": "^4.17.21",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.2",
    "three": "^0.180.0",
    "three-viewport-gizmo": "^2.2.0",
    "tsx": "^4.20.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17"
  }
}
