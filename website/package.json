{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "dotenv -e .env.local -- docusaurus start",
    "build": "docusaurus build",
    "build:local": "dotenv -e .env.local -- docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run build:local && npx wrangler pages deploy --branch main",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "generate-api-docs": "npx tsx scripts/generate-api-docs.ts",
    "prebuild": "npm run generate-api-docs",
    "version:create": "docusaurus docs:version"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "^3.0.0",
    "@tabler/icons-react": "^3.41.1",
    "clsx": "^2.0.0",
    "docusaurus-plugin-typedoc": "^1.4.2",
    "prism-react-renderer": "^2.3.0",
    "raw-loader": "^4.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
