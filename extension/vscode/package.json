{
  "name": "fluidcad",
  "publisher": "FluidCAD",
  "displayName": "FluidCAD",
  "author": "Marwan Aouida <contact@marwan.dev>",
  "description": "",
  "version": "0.0.10",
  "license": "LGPL-2.1",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fluid-CAD/FluidCAD"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:init.js"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fluidcad.show_scene",
        "title": "Show FluidCAD Scene",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "fluidcad.import_file",
        "title": "Import STEP File",
        "icon": "$(file-add)"
      },
      {
        "command": "fluidcad.export_file",
        "title": "Export Model (STEP/STL)",
        "icon": "$(file-symlink-file)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "fluidcad.show_scene",
          "when": "resourceExtname == .js",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "FluidCAD",
      "properties": {
        "fluidcad.autoUpdatePackage": {
          "type": "boolean",
          "default": false,
          "description": "Automatically update the FluidCAD npm package when the extension version is newer."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bash scripts/prepublish.sh && npm run package",
    "build": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.extension.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit -p tsconfig.extension.json",
    "lint": "eslint src",
    "vsix": "npx @vscode/vsce package --no-dependencies --no-rewrite-relative-links",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.9",
    "eslint": "^9.34.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
  }
}
