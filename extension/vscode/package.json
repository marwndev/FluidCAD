{
  "name": "fluidcad-extension",
  "displayName": "FluidCAD",
  "author": "Marwan Aouida",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:init.js"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "fluidcad.scene_history",
          "name": "Scene History",
          "contextualTitle": "Scene History"
        },
        {
          "id": "fluidcad.scene_shapes",
          "name": "Shapes",
          "contextualTitle": "Shapes"
        }
      ]
    },
    "commands": [
      {
        "command": "fluidcad.show_scene",
        "title": "Show FluidCAD Scene",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "fluidcad.rollback",
        "title": "Rollback",
        "icon": "$(arrow-left)"
      },
      {
        "command": "fluidcad.import_file",
        "title": "Import STEP File",
        "icon": "$(file-add)"
      },
      {
        "command": "fluidcad.shape_properties",
        "title": "Shape Properties",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "fluidcad.show_scene",
          "when": "resourceExtname == .js",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "fluidcad.import_file",
          "when": "view == fluidcad.scene_history",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fluidcad.shape_properties",
          "when": "view == fluidcad.scene_shapes && viewItem == shape",
          "group": "inline"
        },
        {
          "command": "fluidcad.shape_properties",
          "when": "view == fluidcad.scene_shapes && viewItem == shape",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:all": "rm -rf dist/ && npm run compile",
    "vscode:prepublish": "npm run package",
    "build": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.extension.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit -p tsconfig.extension.json",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.9",
    "eslint": "^9.34.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
  }
}
